        },
        "types.UserDetails": {
            "type": "object",
            "properties": {
                "dn": {
                    "type": "string"
                },
                "email": {
                    "type": "string"
                },
                "first_name": {
                    "type": "string"
                },
                "gid_number": {
                    "type": "integer"
                },
                "groups": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "home_dir": {
                    "type": "string"
                },
                "last_name": {
                    "type": "string"
                },
                "shell": {
                    "type": "string"
                },
                "uid": {
                    "type": "string"
                },
                "uid_number": {
                    "type": "integer"
                }
            }
        }
    },
