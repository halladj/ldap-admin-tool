    "definitions": {
        "api.ChangeEmailRequest": {
            "type": "object",
            "required": [
                "email"
            ],
            "properties": {
                "email": {
                    "type": "string",
                    "example": "newemail@example.com"
                }
            }
        },
        "api.ChangePasswordRequest": {
            "type": "object",
            "properties": {
                "password": {
                    "type": "string",
                    "example": "NewP@ss123!"
                }
            }
        },
        "api.ChangePasswordResponse": {
            "type": "object",
            "properties": {
                "password": {
                    "type": "string"
                }
            }
        },
        "api.CreateGroupRequest": {
            "type": "object",
            "required": [
                "name"
            ],
            "properties": {
                "gid": {
                    "type": "integer",
                    "example": 10050
                },
                "name": {
                    "type": "string",
                    "example": "printing-c"
                }
            }
        },
        "api.CreateUserRequest": {
            "type": "object",
            "required": [
                "email",
                "first_name",
                "last_name"
            ],
            "properties": {
                "email": {
                    "type": "string",
                    "example": "jdoe@example.com"
                },
                "first_name": {
                    "type": "string",
                    "example": "John"
                },
                "gid": {
                    "type": "integer",
                    "example": 10008
                },
                "groups": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "last_name": {
                    "type": "string",
                    "example": "Doe"
                },
                "password": {
                    "type": "string",
                    "example": "MyP@ss123!"
                },
                "send_email": {
                    "type": "boolean",
                    "example": true
                },
                "send_pdf": {
                    "type": "boolean",
                    "example": true
                },
                "uid": {
                    "type": "string",
                    "example": "jdoe"
                }
            }
        },
        "api.CreateUserResponse": {
            "type": "object",
            "properties": {
                "email_sent": {
                    "type": "boolean"
                },
                "groups": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "uid": {
                    "type": "string"
                },
                "uid_number": {
                    "type": "integer"
                }
            }
        },
        "api.ErrorResponse": {
            "type": "object",
            "properties": {
                "error": {
                    "type": "string",
                    "example": "user 'jdoe' not found"
                }
            }
        },
        "api.GroupMembersRequest": {
            "type": "object",
            "required": [
                "uids"
            ],
            "properties": {
                "uids": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "api.UserGroupsRequest": {
            "type": "object",
            "required": [
                "groups"
            ],
            "properties": {
                "groups": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "types.GroupDetails": {
            "type": "object",
            "properties": {
                "dn": {
